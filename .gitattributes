# Normalizacion de fin de linea (line endings).
#
# El repo almacena texto con LF (normalizado), pero las fuentes .NET se EXTRAEN como
# CRLF en el working tree de cualquier SO para coincidir con `.editorconfig`
# (end_of_line = crlf). Asi `dotnet format --verify-no-changes` es consistente en
# Windows (local) y en el runner Linux del CI, evitando errores ENDOFLINE.

* text=auto

*.cs       text eol=crlf
*.csproj   text eol=crlf
*.props    text eol=crlf
*.targets  text eol=crlf
*.sln      text eol=crlf
*.editorconfig text eol=crlf

# Archivos que deben conservar LF (scripts shell), por si se agregan.
*.sh       text eol=lf
